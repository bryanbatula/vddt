# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Session (use a long random string in production) ──────
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── Local PostgreSQL (development only) ───────────────────
# When DATABASE_URL is NOT set, the app uses these variables.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vddt_db
DB_USER=postgres
DB_PASSWORD=your_local_password

# ── Production PostgreSQL (Supabase) ──────────────────────
# When DATABASE_URL IS set, the app uses this instead of DB_* vars.
# Get this from: Supabase Dashboard > Settings > Database > URI
# Example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

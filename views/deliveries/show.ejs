<%- include('../partials/header') %>

<nav class="breadcrumb">
  <a href="/">Dashboard</a>
  <i data-feather="chevron-right"></i>
  <a href="/deliveries">Deliveries</a>
  <i data-feather="chevron-right"></i>
  <span>Delivery #<%= delivery.id %></span>
</nav>

<!-- ── Header Row ─────────────────────────────────── -->
<div class="detail-header">
  <div>
    <h2 class="detail-title"><%= delivery.product_name %></h2>
    <p class="detail-sub">
      PO: <a href="/orders/<%= delivery.po_id %>" class="link-subtle"><%= delivery.po_number %></a>
      &nbsp;·&nbsp; Vendor: <strong><%= delivery.vendor_name %></strong>
    </p>
  </div>
  <div class="detail-actions">
    <a href="/deliveries/<%= delivery.id %>/edit" class="btn btn-outline">
      <i data-feather="edit-2"></i> Edit
    </a>
    <form action="/deliveries/<%= delivery.id %>?_method=DELETE" method="POST" style="display:inline"
          onsubmit="return confirm('Delete this delivery record?')">
      <button type="submit" class="btn btn-danger">
        <i data-feather="trash-2"></i> Delete
      </button>
    </form>
  </div>
</div>

<!-- ── Detail Cards ───────────────────────────────── -->
<div class="detail-grid">
  <section class="card">
    <div class="card-header"><h3 class="card-title">Product Info</h3></div>
    <div class="card-body detail-list">
      <div class="detail-row"><span>Product</span><strong><%= delivery.product_name %></strong></div>
      <div class="detail-row"><span>SKU</span><strong><%= delivery.sku || '—' %></strong></div>
      <div class="detail-row"><span>Unit</span><strong><%= delivery.unit %></strong></div>
      <div class="detail-row"><span>Unit Price</span><strong>₱<%= parseFloat(delivery.unit_price).toLocaleString('en-PH', {minimumFractionDigits:2}) %></strong></div>
    </div>
  </section>

  <section class="card">
    <div class="card-header"><h3 class="card-title">Quantity Analysis</h3></div>
    <div class="card-body detail-list">
      <div class="detail-row">
        <span>Expected Qty</span>
        <strong><%= delivery.expected_quantity %></strong>
      </div>
      <div class="detail-row">
        <span>Actual Qty Received</span>
        <strong><%= delivery.actual_quantity %></strong>
      </div>
      <div class="detail-row">
        <span>Damaged Qty</span>
        <strong class="<%= delivery.damaged_quantity > 0 ? 'text-danger' : '' %>">
          <%= delivery.damaged_quantity %>
        </strong>
      </div>
      <div class="detail-row">
        <span>Variance</span>
        <strong class="<%= delivery.quantity_variance < 0 ? 'text-danger' : delivery.quantity_variance > 0 ? 'text-over' : 'text-success' %>">
          <%= delivery.quantity_variance > 0 ? '+' : '' %><%= delivery.quantity_variance %>
        </strong>
      </div>
      <div class="detail-row">
        <span>Shrinkage %</span>
        <strong class="<%= parseFloat(delivery.shrinkage_percentage) > 0 ? 'text-danger' : 'text-success' %>">
          <%= parseFloat(delivery.shrinkage_percentage).toFixed(4) %>%
        </strong>
      </div>
      <div class="detail-row">
        <span>Estimated Loss (₱)</span>
        <strong class="text-danger">
          ₱<%= (Math.abs(delivery.quantity_variance) * parseFloat(delivery.unit_price)).toLocaleString('en-PH', {minimumFractionDigits:2}) %>
        </strong>
      </div>
    </div>
  </section>

  <section class="card">
    <div class="card-header"><h3 class="card-title">Receipt Details</h3></div>
    <div class="card-body detail-list">
      <div class="detail-row">
        <span>Status</span>
        <span class="badge badge--<%= delivery.status.toLowerCase().replace(/[\s-]/g,'') %>">
          <%= delivery.status %>
        </span>
      </div>
      <div class="detail-row"><span>Received By</span><strong><%= delivery.received_by || '—' %></strong></div>
      <div class="detail-row">
        <span>Received At</span>
        <strong>
          <%= new Date(delivery.received_at).toLocaleDateString('en-PH', { dateStyle:'long' }) %>
          at <%= new Date(delivery.received_at).toLocaleTimeString('en-PH', { timeStyle:'short' }) %>
        </strong>
      </div>
      <% if (delivery.notes) { %>
      <div class="detail-row detail-row--notes">
        <span>Notes</span>
        <p><%= delivery.notes %></p>
      </div>
      <% } %>
    </div>
  </section>
</div>

<%- include('../partials/footer') %>
